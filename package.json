{
  "name": "@f12io/coco",
  "description": "A fast and lightweight javascript color conversion library.",
  "version": "2.1.4",
  "type": "module",
  "main": "./dist/f12io-coco.umd.cjs",
  "module": "./dist/f12io-coco.js",
  "types": "./dist/f12io-coco.d.ts",
  "exports": {
    ".": {
      "import": "./dist/f12io-coco.js",
      "require": "./dist/f12io-coco.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "preversion": "tsx scripts/preversion-check.ts && npm run lint && npm run test && npm run build",
    "release": "tsx scripts/release.ts"
  },
  "homepage": "https://github.com/f12io/coco",
  "keywords": [
    "color",
    "conversion",
    "hex",
    "rgb",
    "hsl",
    "hsv",
    "lch",
    "oklch",
    "lab",
    "oklab"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/f12io/coco.git"
  },
  "bugs": {
    "url": "https://github.com/f12io/coco/issues"
  },
  "license": "ROOT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.7.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">= 22"
  }
}